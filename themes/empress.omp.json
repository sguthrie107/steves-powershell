{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} :: {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "powerline",
          "powerline_symbol": "▌",
          "foreground": "#EA80FC",
          "background": "#12005E",
          "template": " PS7 "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "▌",
          "foreground": "#E1BEE7",
          "background": "#4A148C",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "agnoster",
            "max_depth": 4,
            "folder_separator_icon": " / ",
            "home_icon": "~",
            "mapped_locations_enabled": true
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "▌",
          "foreground": "#FFEE58",
          "background": "#1A237E",
          "template": " {{ .HEAD }}{{ if gt .Ahead 0 }} ⇡{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ⇣{{ .Behind }}{{ end }} ",
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "▌",
          "foreground": "#FFCDD2",
          "background": "#B71C1C",
          "template": "{{if .Working.Changed}} ✗ {{.Working.String}} {{end}}",
          "properties": {
            "fetch_status": true
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "▌",
          "foreground": "#B9F6CA",
          "background": "#004D40",
          "template": "{{if .Staging.Changed}} ✓ {{.Staging.String}} {{end}}",
          "properties": {
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#757575",
          "background": "transparent",
          "template": "{{ .CurrentDate | date \"15:04\" }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#EF5350{{ end }}"
          ],
          "foreground": "#EA80FC",
          "template": "> "
        }
      ]
    }
  ]
}
